# Do : 하다 — 환경변수 템플릿
# 실제 키는 .env 에 (커밋 금지)

# ─────────────────────────────────────────────
# Supabase (Phase 1 필수)
# https://supabase.com 프로젝트 > Settings > API
# ─────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
# Edge Function 전용 (절대 클라이언트에 노출 금지)
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────
# Google OAuth (Phase 1 필수 — 2026-05-26 변경: 카카오 → 구글)
# https://console.cloud.google.com > APIs & Services > Credentials
# iOS / Android / Web 클라이언트 ID 각각 발급 (Expo Auth Session 사용)
# ─────────────────────────────────────────────
EXPO_PUBLIC_GOOGLE_CLIENT_ID_IOS=
EXPO_PUBLIC_GOOGLE_CLIENT_ID_ANDROID=
EXPO_PUBLIC_GOOGLE_CLIENT_ID_WEB=

# ─────────────────────────────────────────────
# 카카오 (챌린지 초대 링크 공유용 — 로그인은 Phase 1.5로 보류)
# https://developers.kakao.com 내 앱 > 앱 키
# ─────────────────────────────────────────────
EXPO_PUBLIC_KAKAO_NATIVE_APP_KEY=
KAKAO_REST_API_KEY=

# ─────────────────────────────────────────────
# Cloudflare R2 (Phase 1 필수 — 인증 사진 저장소)
# https://dash.cloudflare.com > R2 > Manage R2 API Tokens
# 버킷명 예: do-hada-proofs
# ─────────────────────────────────────────────
EXPO_PUBLIC_R2_ACCOUNT_ID=
EXPO_PUBLIC_R2_BUCKET=do-hada-proofs
EXPO_PUBLIC_R2_PUBLIC_URL=
# Edge Function (presigned URL 발급) 전용 — 클라이언트 노출 금지
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# ─────────────────────────────────────────────
# Sentry (선택 — 에러 모니터링)
# https://sentry.io → 새 프로젝트 (React Native) → DSN 복사
# 비워두면 비활성 모드 (console.warn 대체)
# ─────────────────────────────────────────────
EXPO_PUBLIC_SENTRY_DSN=

# ─────────────────────────────────────────────
# Anthropic (Phase 1.5+ 콘텐츠 검수용 — MVP 베타엔 없어도 됨)
# https://console.anthropic.com
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY=
